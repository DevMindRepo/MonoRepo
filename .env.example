# Database (Supabase)
# DATABASE_URL = pooled connection (runtime queries, port 6543)
# DIRECT_URL   = direct connection (migrations only, port 5432)
# NOTE: If password contains special chars like @ ! # $ &, URL-encode them
#   @ → %40   ! → %21   # → %23   $ → %24   & → %26
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxx:[PASSWORD]@aws-X-region.pooler.supabase.com:5432/postgres"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-min-32-chars-here"

# Sui
SUI_NETWORK="testnet"
SUI_MASTER_WALLET_PHRASE="your twelve word mnemonic phrase here for devmind backend wallet"
WORKSPACE_REGISTRY_PACKAGE_ID="0x0"
SEAL_POLICY_PACKAGE_ID="0x0"

# Walrus
WALRUS_PUBLISHER_URL="https://publisher.walrus-testnet.walrus.space"
WALRUS_AGGREGATOR_URL="https://aggregator.walrus-testnet.walrus.space"

# Gemini / Embeddings
GEMINI_API_KEY="AIza..."

# GitHub Webhook
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"
GITHUB_APP_TOKEN="ghp_..."

# API Server
PORT=3001
API_BASE_URL="http://localhost:3001"

# MCP Server
MCP_API_BASE_URL="http://localhost:3001"
MCP_WORKSPACE_ID="your-workspace-id"
MCP_TOKEN="your-jwt-token"
