generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector"), pg_stat_statements, pgcrypto, uuidOssp(map: "uuid-ossp")]
}

model User {
  id          String   @id @default(cuid())
  suiAddress  String   @unique
  displayName String?
  createdAt   DateTime @default(now())

  workspaceMembers WorkspaceMember[]
  memories         Memory[]
  artifacts        Artifact[]
  pendingMemories  PendingMemory[]
  apiTokens        ApiToken[]
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  ownerId          String
  suiObjectId      String?
  walrusRoot       String?
  memwalNamespace  String?  // MemWal namespace used for this workspace's memory layer
  createdAt        DateTime @default(now())

  members         WorkspaceMember[]
  memories        Memory[]
  artifacts       Artifact[]
  pendingMemories PendingMemory[]
  apiTokens       ApiToken[]
  webhooks        GitHubWebhook[]
  agentRuns       AgentRun[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Memory {
  id              String   @id @default(cuid())
  workspaceId     String
  authorId        String
  content         String   // Plaintext cached for display. Source of truth = MemWal (encrypted on Walrus).
  type            String
  privacy         String   @default("team")
  status          String   @default("pending_approval")
  tags            String[]
  memwalMemoryId  String?  // ID returned by MemWal.remember() — points to the encrypted memory in Walrus
  source          String?
  sessionId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
}

model PendingMemory {
  id          String   @id @default(cuid())
  workspaceId String
  authorId    String
  content     String
  type        String
  privacy     String   @default("team")
  tags        String[]
  secretFlags String[]
  source      String?
  sessionId   String?
  redisKey    String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
}

model Artifact {
  id              String   @id @default(cuid())
  workspaceId     String
  authorId        String
  filename        String
  type            String
  memwalMemoryId  String   // MemWal memory ID pointing to the file blob (encrypted on Walrus)
  sizeBytes       Int      @default(0)
  source          String?
  relatedMemoryId String?
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String?
  name        String
  tokenHash   String    @unique
  prefix      String
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenHash])
}

model GitHubWebhook {
  id             String    @id @default(cuid())
  workspaceId    String
  repo           String
  event          String    @default("pull_request")
  secret         String
  active         Boolean   @default(true)
  lastDeliveryAt DateTime?
  createdAt      DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, repo, event])
}

model AgentRun {
  id               String   @id @default(cuid())
  workspaceId      String
  agentName        String   @default("pr-reviewer")
  prNumber         Int?
  prTitle          String?
  prUrl            String?
  status           String   @default("running")
  reasoning        String?
  comment          String?
  memoriesQueried  String[]
  reviewPosted     Boolean  @default(false)
  durationMs       Int?
  errorMessage     String?
  createdAt        DateTime @default(now())
  completedAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}
