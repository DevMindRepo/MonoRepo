{
  "name": "@devmind/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:push": "dotenv -e ../.env -- prisma db push",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "bootstrap-mcp": "dotenv -e ../.env -- tsx scripts/bootstrap-mcp.ts"
  },
  "dependencies": {
    "@devmind/shared": "workspace:*",
    "@mysten-incubation/memwal": "^0.0.5",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/websocket": "^11.0.0",
    "@google/generative-ai": "^0.21.0",
    "@mysten/sui": "^2.17.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.0",
    "octokit": "^4.0.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv-cli": "^7.4.4",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
